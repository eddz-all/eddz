{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ProjectPilot",
  "version": "0.1.0",
  "identifier": "com.projectpilot.desktop",
  "build": {
    "beforeDevCommand": "npm run dev:full",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "ProjectPilot",
        "width": 1440,
        "height": 900,
        "minWidth": 1080,
        "minHeight": 720,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "macOS": {
      "signingIdentity": "-"
    },
    "icon": [
      "icons/icon_32.png",
      "icons/icon_128.png",
      "icons/icon_256.png",
      "icons/icon.ico"
    ]
  }
}
